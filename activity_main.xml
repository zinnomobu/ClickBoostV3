<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F1A"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Logo / title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡ ClickBoost"
            android:textColor="#FF6B35"
            android:textSize="36sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 tap → multiply your clicks"
            android:textColor="#888888"
            android:textSize="14sp"
            android:layout_marginBottom="32dp" />

        <!-- Permission status card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E2E"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PERMISSIONS"
                android:textColor="#FF6B35"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvOverlayStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Overlay Permission: Checking..."
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvAccessibilityStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Accessibility Service: Checking..."
                android:textColor="#CCCCCC"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Click Multiplier card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E2E"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/lblMultiplier"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Click Multiplier: 5x"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1 tap you press → this many taps registered"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginBottom="12dp" />

            <SeekBar
                android:id="@+id/seekMultiplier"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="19"
                android:progress="4"
                android:thumbTint="#FF6B35"
                android:progressTint="#FF6B35" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="1x" android:textColor="#666" android:textSize="11sp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="20x" android:textColor="#666" android:textSize="11sp"
                    android:gravity="end"/>
            </LinearLayout>
        </LinearLayout>

        <!-- CPS card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E2E"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/lblCPS"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Speed: 10 clicks/sec"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="How fast the extra clicks fire after your tap"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginBottom="12dp" />

            <SeekBar
                android:id="@+id/seekCPS"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="29"
                android:progress="9"
                android:thumbTint="#FF6B35"
                android:progressTint="#FF6B35" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="1 cps" android:textColor="#666" android:textSize="11sp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="30 cps" android:textColor="#666" android:textSize="11sp"
                    android:gravity="end"/>
            </LinearLayout>
        </LinearLayout>

        <!-- How to use card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1A2A"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HOW TO USE"
                android:textColor="#FF6B35"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Set multiplier and speed above\n2. Tap Launch — a floating ⚡ button appears\n3. Drag it over the button you want to boost\n4. Tap ⚡ — it fires your multiplied clicks\n5. Tap ✕ to close the overlay"
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

        <!-- Launch button -->
        <Button
            android:id="@+id/btnLaunch"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🚀 Launch Overlay"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#FF6B35"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="40dp" />

    </LinearLayout>
</ScrollView>
